# API Keys
TAVILY_API_KEY=your_tavily_api_key_here
LLAMA_CLOUD_API_KEY=your_llamaparse_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# PostgreSQL (Supabase)
# Connection pooling for application queries (Prisma)
DATABASE_URL=postgresql://postgres.USERNAME:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Direct connection for migrations and LightRAG PG storage
DIRECT_URL=postgresql://postgres.USERNAME:PASSWORD@HOST:5432/postgres

# Neo4j (AuraDB)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# LangSmith (Observability)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=founder-context-engine

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
